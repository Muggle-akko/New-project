---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  buildSidebarTree,
  formatLongDate,
  getNoteFolderLabel,
  getNoteTitle,
  getRecentNotes,
  noteUrlFromId,
} from "../lib/notes";
import { SITE } from "../lib/site";

const notes = await getCollection(
  "notes",
  ({ data }) => !import.meta.env.PROD || !data.draft,
);
const tree = buildSidebarTree(notes);
const recentNotes = getRecentNotes(notes, 6);
---

<BaseLayout title={SITE.title} description={SITE.description} tree={tree}>
  <section class="rounded-[1.75rem] border border-[var(--border)] bg-[var(--soft)]/55 p-6 sm:p-8">
    <p class="text-xs uppercase tracking-[0.34em] text-[var(--muted)]">个人主页</p>
    <h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-tight tracking-tight text-[var(--foreground)] sm:text-5xl">
      阿巫的数字花园
    </h1>
    <div class="mt-6 max-w-3xl space-y-5 text-base leading-8 text-[var(--muted)]">
      <p>
        你好，我是阿巫，这里是我的数字花园，是我写垃圾话、编鬼点子的地方。
        在「想法」中，我喜欢写一些突如其来的思考，不一定严肃，但起码在用脑子想。希望能给你一些灵感或者帮助。
      </p>
      <p>
        「心情」则是我写流水账的地方，和朋友圈不同，里面的内容会更私人，更情绪化，或者偏向记录。希望你能从我的无聊人生里找到点乐子。
      </p>
      <p>
        没有评论功能，有想说的可以私信我，再有就是多来踩踩。
      </p>
      <p>友情链接开放中，欢迎联系。</p>
    </div>
  </section>

  <section class="mt-8 rounded-[1.75rem] border border-[var(--border)] bg-[var(--bg)]/50 p-6 sm:p-8">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="text-xs uppercase tracking-[0.34em] text-[var(--muted)]">最近笔记</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-[var(--foreground)]">最近更新</h2>
      </div>
      <a href="/notes" class="text-sm text-[var(--accent)] transition hover:opacity-80">时间树 →</a>
    </div>

    {
      recentNotes.length ? (
        <div class="mt-6 divide-y divide-[var(--border)]/80">
          {recentNotes.map((note) => (
            <a
              href={noteUrlFromId(note.id)}
              class="grid gap-3 py-4 transition hover:translate-x-1 md:grid-cols-[1fr_auto] md:items-center"
            >
              <div>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  <h3 class="text-lg font-semibold text-[var(--foreground)]">{getNoteTitle(note)}</h3>
                  <span class="text-xs text-[var(--muted)]">来自 {getNoteFolderLabel(note.id)}</span>
                </div>
                {note.data.description && (
                  <p class="mt-2 max-w-2xl text-sm leading-7 text-[var(--muted)]">{note.data.description}</p>
                )}
              </div>
              <time class="text-sm text-[var(--muted)]">{formatLongDate(note.data.date)}</time>
            </a>
          ))}
        </div>
      ) : (
        <p class="mt-6 text-sm text-[var(--muted)]">还没有公开笔记。</p>
      )
    }
  </section>
</BaseLayout>