---
import { getCollection } from "astro:content";
import SearchableNotesList from "../../components/SearchableNotesList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildSearchableNotes, buildSidebarTree } from "../../lib/notes";

const notes = await getCollection(
  "notes",
  ({ data }) => !import.meta.env.PROD || !data.draft,
);
const tree = buildSidebarTree(notes);
const searchNotes = buildSearchableNotes(notes);
---

<BaseLayout title="时间树" description="浏览时间树。" tree={tree} pageContentClass="page-content-no-shift">
  <section>
    <p class="text-xs uppercase tracking-[0.34em] text-[var(--muted)]">目录</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[var(--foreground)]">时间树</h1>
    <p class="mt-4 max-w-2xl text-base leading-8 text-[var(--muted)]">
      这已经是我的全部了。
    </p>
  </section>

  <SearchableNotesList notes={searchNotes} />
</BaseLayout>

