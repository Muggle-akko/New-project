---
interface SearchableNote {
  url: string;
  path: string;
  title: string;
  dateLabel: string;
  dateYear: string;
  dateMonth: string;
  dateDay: string;
  dateMonthDay: string;
  dateYearKey: string;
  dateMonthKey: string;
  description: string;
  tags: string[];
  content: string;
}

interface Props {
  notes: SearchableNote[];
}

const { notes } = Astro.props as Props;
const serializedNotes = JSON.stringify(notes).replace(/<\/script/gi, "<\\/script");
const excerptLength = 140;
const getContentPreview = (content: string) => {
  const text = content.trim();
  if (!text) return "";
  return text.length > excerptLength ? `${text.slice(0, excerptLength).trim()}…` : text;
};
const getTimelinePathLabel = (path: string) => {
  const folders = path
    .split("/")
    .slice(0, -1)
    .filter((part) => !/^\d{4}$/.test(part) && !/^\d{1,2}月$/.test(part));

  return folders.join(" / ") || "顶层";
};
const timeTreeEntries = notes.map((note, index) => {
  const previous = notes[index - 1];

  return {
    note,
    preview: getContentPreview(note.content),
    timelinePath: getTimelinePathLabel(note.path),
    isFirstYear: !previous || previous.dateYearKey !== note.dateYearKey,
    isFirstMonth: !previous || previous.dateMonthKey !== note.dateMonthKey,
  };
});
const yearLinks = timeTreeEntries
  .filter((entry) => entry.isFirstYear)
  .map(({ note }) => ({ key: note.dateYearKey, label: note.dateYear }));
const firstEntry = timeTreeEntries[0];
---

<section class="mt-8 space-y-4" data-note-search data-time-tree-ready="false">
  <div class="surface-panel search-panel rounded-[1.5rem] p-4 sm:p-5">
    <label for="note-search-input" class="search-label">搜索笔记</label>
    <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center">
      <div class="search-input-wrap flex-1">
        <svg class="search-glyph" viewBox="0 0 24 24" aria-hidden="true"><path d="m20 20-4.35-4.35m2.35-5.15a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" /></svg>
        <input
          id="note-search-input"
          type="search"
          placeholder="在时间的长藤中，愿我们都能找到彼此"
          autocomplete="off"
          spellcheck="false"
          class="search-input w-full"
          data-search-input
        />
      </div>

    </div>
    <p class="mt-3 text-sm text-[var(--muted)]" data-search-count>共 {notes.length} 篇笔记</p>
  </div>

  <div
    class="search-empty surface-panel hidden rounded-[1.5rem] px-5 py-6 text-sm leading-7 text-[var(--muted)]"
    data-search-empty
  >
    没有找到匹配的笔记，试试更短的关键词，或换成标题、路径、标签里的词。
  </div>

  <div class="time-tree-layout" data-time-tree>
    <div class="time-tree-items" data-search-list>
      {
        timeTreeEntries.map(({ note, preview, timelinePath, isFirstYear, isFirstMonth }) => (
          <div
            class="time-tree-entry"
            data-time-tree-entry
            data-year={note.dateYear}
            data-year-key={note.dateYearKey}
            data-month={note.dateMonth}
            data-month-key={note.dateMonthKey}
            data-year-anchor={`year-${note.dateYearKey}`}
            data-month-anchor={`month-${note.dateMonthKey}`}
          >
            {isFirstYear && <span id={`year-${note.dateYearKey}`} class="time-tree-anchor" aria-hidden="true"></span>}
            {isFirstMonth && <span id={`month-${note.dateMonthKey}`} class="time-tree-anchor" aria-hidden="true"></span>}
            <a
              href={note.url}
              class="surface-panel note-search-card time-tree-card block rounded-[1.5rem] p-5 transition hover:-translate-y-0.5"
            >
              <div>
                <p class="text-xs uppercase tracking-[0.28em] text-[var(--muted)]">{timelinePath}</p>
                <h2 class="mt-2 text-xl font-semibold text-[var(--foreground)]">{note.title}</h2>
              </div>
              {preview && (
                <p class="mt-4 max-w-3xl text-sm leading-7 text-[var(--muted)]">{preview}</p>
              )}
              {
                note.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {note.tags.map((tag) => <span class="search-tag">#{tag}</span>)}
                  </div>
                )
              }
            </a>
            <time class="time-tree-date" aria-label={note.dateLabel}>
              <span class="time-tree-date-month">{note.dateMonth}</span>
              <span class="time-tree-date-day">{note.dateDay}</span>
            </time>
          </div>
        ))
      }
    </div>

    {
      firstEntry && (
        <nav class="surface-panel time-tree-rail" aria-label="时间导航">
          <a
            class="time-tree-current-year"
            href={`#year-${firstEntry.note.dateYearKey}`}
            data-time-tree-current-year
          >
            {firstEntry.note.dateYear}
          </a>
          <a
            class="time-tree-current-month"
            href={`#month-${firstEntry.note.dateMonthKey}`}
            data-time-tree-current-month
          >
            {firstEntry.note.dateMonth}
          </a>
          <div class="time-tree-year-links" aria-label="年份跳转">
            {yearLinks.map((year) => (
              <a
                href={`#year-${year.key}`}
                class:list={["time-tree-year-link", { "is-active": year.key === firstEntry.note.dateYearKey }]}
                data-time-tree-year-link
                data-year-key={year.key}
              >
                {year.label}
              </a>
            ))}
          </div>
        </nav>
      )
    }
  </div>

  <script type="application/json" data-search-source set:html={serializedNotes}></script>
</section>

<script is:inline>
  (() => {
    const escapeHtml = (value = "") =>
      value.replace(/[&<>"']/g, (char) => {
        switch (char) {
          case "&":
            return "&amp;";
          case "<":
            return "&lt;";
          case ">":
            return "&gt;";
          case '"':
            return "&quot;";
          case "'":
            return "&#39;";
          default:
            return char;
        }
      });

    const escapeRegExp = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    const tokenize = (value) =>
      Array.from(new Set(value.toLocaleLowerCase().trim().split(/\s+/).filter(Boolean)));
    const formatTimelinePathLabel = (path = "") => {
      const folders = path
        .split("/")
        .slice(0, -1)
        .filter((part) => !/^\d{4}$/.test(part) && !/^\d{1,2}月$/.test(part));

      return folders.join(" / ") || "顶层";
    };

    const includesAny = (text, terms) => terms.some((term) => text.includes(term));

    const highlightText = (value, terms) => {
      const escaped = escapeHtml(value);
      if (!terms.length) return escaped;

      const pattern = new RegExp(`(${terms.map(escapeRegExp).join("|")})`, "gi");
      return escaped.replace(pattern, '<mark class="search-highlight">$1</mark>');
    };

    const findSnippet = (note, terms) => {
      const description = note.description ?? "";
      const content = note.content ?? "";
      const descriptionLower = description.toLocaleLowerCase();
      const contentLower = content.toLocaleLowerCase();

      let source = description;
      let sourceLower = descriptionLower;

      if (!includesAny(descriptionLower, terms) && includesAny(contentLower, terms)) {
        source = content;
        sourceLower = contentLower;
      }

      if (!source) return "";

      const matchIndex = terms.reduce((current, term) => {
        const index = sourceLower.indexOf(term);
        if (index === -1) return current;
        return current === -1 ? index : Math.min(current, index);
      }, -1);

      if (matchIndex === -1) {
        return source.slice(0, 120).trim();
      }

      const start = Math.max(0, matchIndex - 28);
      const end = Math.min(source.length, matchIndex + 92);
      const snippet = source.slice(start, end).trim();

      return `${start > 0 ? "…" : ""}${snippet}${end < source.length ? "…" : ""}`;
    };

    const renderTags = (tags, terms) => {
      if (!tags.length) return "";

      return `
        <div class="mt-4 flex flex-wrap gap-2">
          ${tags
            .map((tag) => `<span class="search-tag">#${highlightText(tag, terms)}</span>`)
            .join("")}
        </div>
      `;
    };

    const renderCard = (note, terms) => {
      const snippet = terms.length ? findSnippet(note, terms) : note.description;
      const displayDate = note.dateMonthDay ?? note.dateLabel;
      const pathLabel = formatTimelinePathLabel(note.path);

      return `
        <a
          href="${escapeHtml(note.url)}"
          class="surface-panel note-search-card block rounded-[1.5rem] p-5 transition hover:-translate-y-0.5"
        >
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-xs uppercase tracking-[0.28em] text-[var(--muted)]">${highlightText(pathLabel, terms)}</p>
              <h2 class="mt-2 text-xl font-semibold text-[var(--foreground)]">${highlightText(note.title, terms)}</h2>
            </div>
            <time class="pill">${escapeHtml(displayDate)}</time>
          </div>
          ${snippet ? `<p class="mt-4 max-w-3xl text-sm leading-7 text-[var(--muted)]">${highlightText(snippet, terms)}</p>` : ""}
          ${renderTags(note.tags, terms)}
        </a>
      `;
    };

    document.querySelectorAll("[data-note-search]").forEach((container) => {
      if (container.dataset.ready === "true") return;
      container.dataset.ready = "true";

      const input = container.querySelector("[data-search-input]");
      const count = container.querySelector("[data-search-count]");
      const list = container.querySelector("[data-search-list]");
      const empty = container.querySelector("[data-search-empty]");
      const source = container.querySelector("[data-search-source]");
      const timeTree = container.querySelector("[data-time-tree]");
      const currentYear = container.querySelector("[data-time-tree-current-year]");
      const currentMonth = container.querySelector("[data-time-tree-current-month]");

      if (!(input instanceof HTMLInputElement) || !count || !list || !empty || !source) {
        return;
      }

      const initialMarkup = list.innerHTML;
      const notes = JSON.parse(source.textContent ?? "[]").map((note) => ({
        ...note,
        description: note.description ?? "",
        content: note.content ?? "",
        tags: Array.isArray(note.tags) ? note.tags : [],
        searchText: [note.title, note.path, note.description, (note.tags ?? []).join(" "), note.content]
          .join(" ")
          .toLocaleLowerCase(),
      }));

      const setTimeTreeSearchMode = (isSearching) => {
        timeTree?.classList.toggle("is-searching", isSearching);
      };

      const updateTimeTree = () => {
        if (!timeTree || !(currentYear instanceof HTMLAnchorElement) || !(currentMonth instanceof HTMLAnchorElement)) {
          return;
        }

        const entries = Array.from(timeTree.querySelectorAll("[data-time-tree-entry]"));
        if (!entries.length || timeTree.classList.contains("is-searching")) return;

        const threshold = Math.min(window.innerHeight * 0.32, 220);
        let active = entries[0];

        for (const entry of entries) {
          const top = entry.getBoundingClientRect().top;
          if (top <= threshold) {
            active = entry;
          } else {
            break;
          }
        }

        const year = active.dataset.year ?? "";
        const month = active.dataset.month ?? "";
        const yearAnchor = active.dataset.yearAnchor;
        const monthAnchor = active.dataset.monthAnchor;

        currentYear.textContent = year;
        currentMonth.textContent = month;
        if (yearAnchor) currentYear.setAttribute("href", `#${yearAnchor}`);
        if (monthAnchor) currentMonth.setAttribute("href", `#${monthAnchor}`);

        timeTree.querySelectorAll("[data-time-tree-year-link]").forEach((link) => {
          link.classList.toggle("is-active", link.dataset.yearKey === active.dataset.yearKey);
        });
      };

      let timeTreeUpdateQueued = false;
      const requestTimeTreeUpdate = () => {
        if (timeTreeUpdateQueued) return;
        timeTreeUpdateQueued = true;
        window.requestAnimationFrame(() => {
          timeTreeUpdateQueued = false;
          updateTimeTree();
        });
      };

      if (timeTree) {
        window.addEventListener("scroll", requestTimeTreeUpdate, { passive: true });
        window.addEventListener("resize", requestTimeTreeUpdate);
        updateTimeTree();
        window.requestAnimationFrame(() => {
          updateTimeTree();
          window.requestAnimationFrame(() => {
            updateTimeTree();
            container.dataset.timeTreeReady = "true";
          });
        });
      } else {
        container.dataset.timeTreeReady = "true";
      }

      const syncUrl = (query) => {
        const url = new URL(window.location.href);
        if (query) {
          url.searchParams.set("q", query);
        } else {
          url.searchParams.delete("q");
        }
        window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
      };

      const render = (query, { updateUrl = true } = {}) => {
        const normalizedQuery = query.trim();
        const terms = tokenize(normalizedQuery);

        if (!terms.length) {
          setTimeTreeSearchMode(false);
          list.innerHTML = initialMarkup;
          empty.classList.add("hidden");
          count.textContent = `共 ${notes.length} 篇笔记`;
          updateTimeTree();
          if (updateUrl) syncUrl("");
          return;
        }

        const results = notes.filter((note) => terms.every((term) => note.searchText.includes(term)));

        setTimeTreeSearchMode(true);
        list.innerHTML = results.map((note) => renderCard(note, terms)).join("");
        empty.classList.toggle("hidden", results.length !== 0);
        count.textContent = results.length ? `找到 ${results.length} 篇相关笔记` : "没有找到相关笔记";

        if (updateUrl) syncUrl(normalizedQuery);
      };

      input.addEventListener("input", () => {
        render(input.value);
      });

      const initialQuery = new URLSearchParams(window.location.search).get("q") ?? "";
      if (initialQuery.trim()) {
        input.value = initialQuery;
        render(initialQuery, { updateUrl: false });
      }
    });
  })();
</script>
