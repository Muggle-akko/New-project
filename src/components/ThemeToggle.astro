<div class="flex items-center justify-between gap-3 rounded-[1.35rem] border border-[var(--border)] bg-[var(--soft)]/70 px-4 py-3">
  <span class="text-xs uppercase tracking-[0.28em] text-[var(--muted)]">Theme</span>
  <div class="grid grid-cols-3 gap-2 rounded-full border border-[var(--border)] bg-[var(--bg)]/70 p-1">
    <button class="theme-option" type="button" data-theme-option="light">Light</button>
    <button class="theme-option" type="button" data-theme-option="dark">Dark</button>
    <button class="theme-option" type="button" data-theme-option="system">System</button>
  </div>
</div>
