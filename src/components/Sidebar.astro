---
import ThemeToggle from "./ThemeToggle.astro";
import SidebarTree from "./SidebarTree.astro";
import { getOpenFolderPaths } from "../lib/notes";
import type { SidebarNode } from "../lib/notes";
import { SITE } from "../lib/site";

interface Props {
  tree: SidebarNode[];
  currentNotePath?: string;
}

const { tree, currentNotePath } = Astro.props;
const openFolders = getOpenFolderPaths(currentNotePath);
---

<div class="sidebar-shell flex h-full flex-col gap-5 p-4 lg:p-0">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-xs uppercase tracking-[0.32em] text-[var(--muted)]">目录</p>
      <a href="/" class="mt-2 block text-xl font-semibold tracking-tight text-[var(--foreground)]">
        {SITE.title}
      </a>
      <p class="mt-2 text-xs leading-6 text-[var(--muted)]">{SITE.description}</p>
    </div>
    <button
      type="button"
      data-sidebar-close
      class="inline-flex h-10 w-10 items-center justify-center rounded-full text-sm text-[var(--muted)] transition hover:bg-[var(--soft)] hover:text-[var(--foreground)] lg:hidden"
      aria-label="关闭目录"
    >
      ×
    </button>
  </div>

  <button type="button" class="sidebar-search-trigger text-left" data-search-open aria-label="打开搜索">
    <span class="search-input-wrap sidebar-search-wrap block">
      <svg class="search-glyph" viewBox="0 0 24 24" aria-hidden="true"><path d="m20 20-4.35-4.35m2.35-5.15a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" /></svg>
      <span class="search-input sidebar-search-input sidebar-search-faux flex w-full items-center text-[var(--muted)]">
        探索
      </span>
    </span>
  </button>

  <ThemeToggle />

  <nav class="min-h-0 flex-1 overflow-y-auto pr-1">
    {
      tree.length ? (
        <SidebarTree nodes={tree} currentNotePath={currentNotePath} openFolders={openFolders} />
      ) : (
        <p class="px-2 py-4 text-sm leading-7 text-[var(--muted)]">
          在 <code class="rounded bg-[var(--soft)] px-1.5 py-0.5 text-xs">vault/</code>
          新建第一篇笔记后，这里会自动生成目录树。
        </p>
      )
    }
  </nav>
</div>


