---
import { getCollection } from "astro:content";
import SearchOverlay from "../components/SearchOverlay.astro";
import Sidebar from "../components/Sidebar.astro";
import "../styles/global.css";
import { buildSearchableNotes } from "../lib/notes";
import type { SidebarNode } from "../lib/notes";
import { SITE } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  tree: SidebarNode[];
  currentNotePath?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  tree,
  currentNotePath,
} = Astro.props;
const pageTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
const allNotes = await getCollection(
  "notes",
  ({ data }) => !import.meta.env.PROD || !data.draft,
);
const searchNotes = buildSearchableNotes(allNotes);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const themeKey = "note-theme";
        const storedTheme = localStorage.getItem(themeKey) ?? "light";

        document.documentElement.dataset.theme = storedTheme;
        document.documentElement.classList.toggle("dark", storedTheme === "dark");
        document.documentElement.style.colorScheme = storedTheme;
      })();
    </script>
  </head>
  <body class="antialiased">
    <header class="frost-header sticky top-0 z-30 border-b border-[var(--border)] backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 lg:px-6">
        <div class="flex items-center gap-3">
          <button
            type="button"
            data-sidebar-toggle
            class="inline-flex h-10 items-center justify-center rounded-full border border-[var(--border)] px-4 text-sm text-[var(--foreground)] transition hover:border-[var(--accent)] lg:hidden"
          >
            目录
          </button>
          <a href="/" class="text-sm uppercase tracking-[0.32em] text-[var(--muted)]">{SITE.title}</a>
        </div>

        <a
          href="/notes"
          class="inline-flex items-center rounded-full border border-[var(--border)] px-4 py-2 text-sm text-[var(--foreground)] transition hover:border-[var(--accent)] hover:bg-[var(--soft)]"
        >
          全部笔记
        </a>
      </div>
    </header>

    <div class="relative mx-auto flex max-w-7xl gap-6 px-4 py-6 lg:px-6">
      <div data-sidebar-backdrop class="fixed inset-0 z-30 hidden bg-slate-950/45 lg:hidden"></div>

      <aside
        data-sidebar-panel
        class="fixed inset-y-0 left-0 z-40 w-[min(86vw,22rem)] -translate-x-full px-4 py-4 transition-transform duration-200 lg:sticky lg:top-24 lg:h-[calc(100vh-7rem)] lg:w-80 lg:translate-x-0 lg:px-0 lg:py-0"
      >
        <Sidebar tree={tree} currentNotePath={currentNotePath} />
      </aside>

      <main class="min-w-0 flex-1 lg:pl-2">
        <div class="note-shell rounded-[2rem] px-5 py-6 sm:px-7 sm:py-7 lg:px-10 lg:py-9">
          <slot />
        </div>
      </main>
    </div>

    <SearchOverlay notes={searchNotes} />

    <script is:inline>
      const themeKey = "note-theme";
      const root = document.documentElement;
      const themeToggle = document.querySelector("[data-theme-toggle]");

      const applyTheme = (theme) => {
        root.dataset.theme = theme;
        root.classList.toggle("dark", theme === "dark");
        root.style.colorScheme = theme;
        themeToggle?.setAttribute("data-theme", theme);
        themeToggle?.setAttribute("aria-pressed", String(theme === "dark"));
        themeToggle?.setAttribute(
          "title",
          theme === "dark" ? "切换到明亮模式" : "切换到深色模式",
        );
      };

      const readTheme = () => localStorage.getItem(themeKey) ?? "light";

      themeToggle?.addEventListener("click", () => {
        const nextTheme = readTheme() === "dark" ? "light" : "dark";
        localStorage.setItem(themeKey, nextTheme);
        applyTheme(nextTheme);
      });

      applyTheme(readTheme());

      const sidebarPanel = document.querySelector("[data-sidebar-panel]");
      const sidebarBackdrop = document.querySelector("[data-sidebar-backdrop]");

      const openSidebar = () => {
        sidebarPanel?.classList.remove("-translate-x-full");
        sidebarBackdrop?.classList.remove("hidden");
        document.body.classList.add("overflow-hidden");
      };

      const closeSidebar = () => {
        sidebarPanel?.classList.add("-translate-x-full");
        sidebarBackdrop?.classList.add("hidden");
        if (!document.body.classList.contains("search-modal-open")) {
          document.body.classList.remove("overflow-hidden");
        }
      };

      document.querySelectorAll("[data-sidebar-toggle]").forEach((button) => {
        button.addEventListener("click", openSidebar);
      });

      document.querySelectorAll("[data-sidebar-close]").forEach((button) => {
        button.addEventListener("click", closeSidebar);
      });

      document.querySelectorAll("[data-search-open]").forEach((button) => {
        button.addEventListener("click", () => {
          closeSidebar();
        });
      });

      sidebarBackdrop?.addEventListener("click", closeSidebar);

      window.addEventListener("resize", () => {
        if (window.innerWidth >= 1024) {
          closeSidebar();
        }
      });
    </script>
  </body>
</html>
